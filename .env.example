NODE_ENV=development
PORT=3000
DATABASE_URL="file:./dev.db"

# X / Twitter API credentials
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# Bot config
BOT_USERNAME=BagsLaunch
POLL_INTERVAL_MS=3000

# Launch provider: "mock" | "bags"
PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
LAUNCH_PROVIDER=bags

# Bags API
BAGS_API_BASE_URL=https://api.bags.fm
BAGS_API_KEY=

# Reply behavior
ENABLE_REPLY_POSTING=true
DEFAULT_REPLY_MODE=public

# Rate limiting
RATE_LIMIT_PER_USER_PER_DAY=5

# Allowlist mode (if true, only allowlisted users can launch)
ALLOWLIST_MODE=false

# Logging
LOG_LEVEL=debug
