{
  "name": "bagsbot",
  "version": "1.0.0",
  "description": "Bags Participation Launch Bot - turns X mentions into Bags-native coin launches",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "bags",
    "bot",
    "twitter",
    "token-launch"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "dependencies": {
    "@bagsfm/bags-sdk": "^1.3.1",
    "@prisma/client": "^6.19.2",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^25.3.5",
    "axios": "^1.13.6",
    "bs58": "^6.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "nanoid": "^5.1.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "twitter-api-v2": "^1.29.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "vitest": "^3.2.4"
  }
}
